generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

enum ChallengeType {
  QUIZ
  PHOTO
  CHECKIN
  SCAVENGER
  SOCIAL
  POLL
  TRIVIA
  REFERRAL
}

enum EvidenceMode {
  PHOTO_UPLOAD
  TEXT
  SHORT_ANSWER
  URL
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Event {
  id                 String      @id @default(cuid())
  title              String
  slug               String      @unique
  eventCode          String?     @unique
  description        String
  date               DateTime
  time               String
  location           String
  category           String
  organizer          String
  notes              String
  imageUrl           String?
  seoTitle           String?
  seoDescription     String?
  scheduledPublishAt DateTime?
  status             EventStatus @default(DRAFT)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  views              EventView[]
  challenges         Challenge[]
  points             PointEntry[]
  activities         Activity[]

  @@index([date])
  @@index([category])
  @@index([status])
  @@index([scheduledPublishAt])
}

model Participant {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Challenge {
  id             String                @id @default(cuid())
  eventId        String
  title          String
  description    String
  type           ChallengeType         @default(QUIZ)
  evidenceMode   EvidenceMode          @default(TEXT)
  autoApproveAnswer String?
  points         Int                   @default(10)
  enabled        Boolean               @default(true)
  isToday        Boolean               @default(false)
  createdAt      DateTime              @default(now())
  event          Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pointEntries   PointEntry[]
  submissions    ChallengeSubmission[]

  @@index([eventId, enabled])
}

model ChallengeSubmission {
  id              String           @id @default(cuid())
  challengeId     String
  eventId         String
  participantId   String
  participantName String
  evidenceText    String?
  evidenceUrl     String?
  evidenceFileUrl String?
  status          SubmissionStatus @default(PENDING)
  reviewNote      String?
  createdAt       DateTime         @default(now())
  reviewedAt      DateTime?
  challenge       Challenge        @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, participantId])
  @@index([eventId, status])
}

model PointEntry {
  id            String    @id @default(cuid())
  eventId       String
  challengeId   String
  participantId String
  points        Int
  createdAt     DateTime  @default(now())
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, participantId])
  @@index([eventId, participantId])
  @@index([createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  eventId   String
  type      String
  message   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

model CategorySubscription {
  id        String   @id @default(cuid())
  email     String
  category  String
  createdAt DateTime @default(now())

  @@unique([email, category])
  @@index([category])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  target    String
  targetId  String
  message   String?
  actor     String
  createdAt DateTime @default(now())

  @@index([target, targetId])
  @@index([createdAt])
}

model AdminCredential {
  id           String   @id @default("singleton")
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EventView {
  id        String   @id @default(cuid())
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([createdAt])
}

model SearchMetric {
  id           String   @id @default(cuid())
  query        String
  category     String?
  view         String?
  resultsCount Int
  createdAt    DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}

model CategoryMetric {
  id        String   @id @default(cuid())
  category  String
  createdAt DateTime @default(now())

  @@index([category])
  @@index([createdAt])
}
